{
  "redirects": [
    { "source": "/admin", "destination": "/admin/", "permanent": false }
  ],
  "headers": [
    {
      "source": "/admin/(.*)",
      "headers": [{ "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }]
    },
    {
      "source": "/admin/",
      "headers": [{ "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }]
    }
  ],
  "functions": {
    "api/transcribe.js": { "maxDuration": 30 },
    "api/transcribe-status.js": { "maxDuration": 10 },
    "api/upload.js": { "maxDuration": 30 },
    "api/file.js": { "maxDuration": 30 }
  }
}
